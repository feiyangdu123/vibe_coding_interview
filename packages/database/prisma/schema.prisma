generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ORG_ADMIN
  INTERVIEWER
}

enum ProblemVisibility {
  PRIVATE
  ORG_SHARED
}

enum ProblemType {
  CODING
  SYSTEM_DESIGN
  ALGORITHM
  DEBUGGING
}

enum InterviewStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  EXPIRED
  CANCELLED
  SUBMITTED
}

enum EndReason {
  TIME_UP
  CANDIDATE_SUBMIT
  INTERVIEWER_STOP
  SYSTEM_ERROR
  CANCELLED_BY_ORG
  CANDIDATE_NO_SHOW
}

enum InterviewEventType {
  STARTED
  WORKSPACE_OPENED
  HEARTBEAT
  SUBMITTED
  TIMEOUT
  INTERVIEWER_ENDED
  SYSTEM_ERROR
  CANCELLED
  NO_SHOW
  AI_EVALUATION_STARTED
  AI_EVALUATION_FINISHED
}

enum InterviewQuotaState {
  RESERVED
  CONSUMED
  RELEASED
}

enum InterviewQuotaLedgerAction {
  GRANT
  RESERVE
  CONSUME
  RELEASE
  ADJUST
}

enum InterviewQuotaLedgerReason {
  ORGANIZATION_CREATED
  INTERVIEW_CREATED
  INTERVIEW_COMPLETED
  INTERVIEW_CANCELLED
  CANDIDATE_NO_SHOW
  SYSTEM_VOID
  MANUAL_ADJUSTMENT
  MIGRATION_BACKFILL
}

model Organization {
  id        String   @id @default(uuid())
  name      String
  slug      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users           User[]
  candidates      Candidate[]
  problems        Problem[]
  interviews      Interview[]
  interviewDrafts InterviewDraft[]
  apiKeyConfigs   OrganizationApiKeyConfig[]
  interviewQuota  OrganizationInterviewQuota?
}

model OrganizationApiKeyConfig {
  id             String   @id @default(uuid())
  organizationId String
  name           String
  baseUrl        String
  apiKey         String   @db.Text
  isSelected     Boolean  @default(false)
  lastUsedAt     DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([organizationId, isSelected])
  @@index([lastUsedAt])
}

model User {
  id             String   @id @default(uuid())
  username       String   @unique
  passwordHash   String
  email          String?
  role           UserRole
  organizationId String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization        Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdProblems     Problem[]     @relation("ProblemCreator")
  conductedInterviews Interview[]   @relation("InterviewInterviewer")
  sessions            AuthSession[]
  interviewDrafts     InterviewDraft[]
  quotaLedgerEntries  InterviewQuotaLedger[] @relation("QuotaLedgerActor")

  @@index([organizationId])
  @@index([username])
}

model AuthSession {
  id        String   @id @default(uuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([userId])
  @@index([expiresAt])
}

model Problem {
  id              String      @id @default(uuid())
  title           String
  description     String      @db.Text
  requirements    String      @db.Text
  scoringCriteria Json
  workDirTemplate String
  duration        Int
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  // 新增字段
  organizationId             String
  createdById                String
  visibility                 ProblemVisibility @default(PRIVATE)
  problemType                ProblemType       @default(CODING)
  roleTrack                  String?
  difficulty                 String?
  language                   String?
  tags                       String[]          @default([])
  evaluationInstructionsText String?           @db.Text
  acceptanceCriteria         Json?

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdBy    User         @relation("ProblemCreator", fields: [createdById], references: [id])
  interviews   Interview[]

  @@index([organizationId])
  @@index([createdById])
  @@index([visibility])
  @@index([problemType])
}

model ProblemTemplate {
  id                         String      @id @default(uuid())
  slug                       String      @unique
  title                      String
  description                String      @db.Text
  requirements               String      @db.Text
  scoringCriteria            Json
  workDirTemplate            String
  duration                   Int
  problemType                ProblemType @default(CODING)
  roleTrack                  String?
  difficulty                 String?
  language                   String?
  tags                       String[]    @default([])
  evaluationInstructionsText String?     @db.Text
  acceptanceCriteria         Json?
  isActive                   Boolean     @default(true)
  createdAt                  DateTime    @default(now())
  updatedAt                  DateTime    @updatedAt

  @@index([isActive])
  @@index([problemType])
}

model Candidate {
  id             String      @id @default(uuid())
  organizationId String
  name           String
  email          String
  phone          String?
  createdAt      DateTime    @default(now())
  interviews     Interview[]
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, email])
  @@index([organizationId])
}

model Interview {
  id              String           @id @default(uuid())
  candidateId     String
  problemId       String
  token           String           @unique
  scheduledStartAt DateTime?
  joinWindowOpensAt DateTime?
  joinDeadlineAt  DateTime?
  startTime       DateTime?
  endTime         DateTime?
  cancelledAt     DateTime?
  submittedAt     DateTime?
  duration        Int
  status          InterviewStatus  @default(PENDING)
  workDir         String?
  dataDir         String?
  port            Int?             @unique
  processId       Int?
  healthStatus    String?
  lastHealthCheck DateTime?
  processError    String?
  createdAt       DateTime         @default(now())

  // 新增字段
  organizationId String
  interviewerId  String?
  endReason      EndReason?
  quotaState     InterviewQuotaState?
  quotaReservedAt DateTime?
  quotaSettledAt DateTime?

  // 快照字段
  candidateSnapshot          Json?
  problemSnapshot            Json?
  evaluationCriteriaSnapshot Json?

  // AI 评估字段
  aiEvaluationStatus  String?   // 'pending' | 'running' | 'completed' | 'failed' | 'timeout'
  aiEvaluationScore   Float?    // 总分 (0-10)
  aiEvaluationDetails String?   @db.Text // 评估结果文本（包含分数和原因）
  aiEvaluationRaw     String?   @db.Text // AI 原始响应
  aiEvaluationError   String?   @db.Text // 错误信息
  aiEvaluatedAt       DateTime? // 评估完成时间
  aiEvaluationRetries Int       @default(0) // 重试次数

  // 人工复核字段
  manualReviewStatus     String?
  manualReviewScore      Float?
  manualReviewNotes      String?   @db.Text
  manualReviewConclusion String?   @db.Text
  manualReviewedAt       DateTime?
  manualReviewedBy       String?

  // Phase 4: 新增字段
  currentAiRunId String? // 当前生效的评估版本 ID
  finalDecision  String? // 'pass' | 'fail' | 'pending'

  // AI 聊天镜像字段
  aiChatMirrorSourceSessionId     String?
  aiChatMirrorSessionId           String?
  aiChatMirrorLastCandidateMessageAt DateTime?
  aiChatMirrorLastUsedAt          DateTime?

  candidate       Candidate          @relation(fields: [candidateId], references: [id])
  problem         Problem            @relation(fields: [problemId], references: [id])
  organization    Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  interviewer     User?              @relation("InterviewInterviewer", fields: [interviewerId], references: [id])
  events          InterviewEvent[]
  aiEvaluationRuns AiEvaluationRun[]
  aiChatMessages  AiChatMessage[]
  quotaLedgerEntries InterviewQuotaLedger[]

  @@index([token])
  @@index([status])
  @@index([organizationId])
  @@index([interviewerId])
  @@index([scheduledStartAt])
  @@index([joinDeadlineAt])
  @@index([quotaState])
  @@index([manualReviewStatus])
  @@index([aiChatMirrorLastUsedAt])
}

model InterviewEvent {
  id          String             @id @default(uuid())
  interviewId String
  eventType   InterviewEventType
  metadata    Json?
  createdAt   DateTime           @default(now())

  interview Interview @relation(fields: [interviewId], references: [id], onDelete: Cascade)

  @@index([interviewId])
  @@index([createdAt])
}

model AiEvaluationRun {
  id          String    @id @default(uuid())
  interviewId String
  version     Int       // 版本号，从 1 开始递增
  status      String    // 'running' | 'completed' | 'failed' | 'timeout'
  score       Float?    // 总分 0-10
  details     Json?     // { dimensions: [...], summary: "..." }
  rawOutput   String?   @db.Text
  error       String?   @db.Text
  triggeredBy String?   // 触发人 userId（自动触发为 null）
  startedAt   DateTime  @default(now())
  completedAt DateTime?
  retries     Int       @default(0)

  interview Interview @relation(fields: [interviewId], references: [id], onDelete: Cascade)

  @@unique([interviewId, version])
  @@index([interviewId, version])
}

model InterviewDraft {
  id             String   @id @default(uuid())
  organizationId String
  createdById    String

  // 表单字段
  positionName      String?
  interviewerId     String?
  problemId         String?
  scheduledStartAt  DateTime?
  duration          Int?
  candidateMode     String? // 'existing' | 'new'
  candidateId       String?
  newCandidateName  String?
  newCandidateEmail String?
  newCandidatePhone String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdBy    User         @relation(fields: [createdById], references: [id], onDelete: Cascade)

  @@unique([organizationId, createdById])
  @@index([createdById])
}

model AiChatMessage {
  id          String   @id @default(uuid())
  interviewId String
  role        String   // 'user' | 'assistant'
  content     String   @db.Text
  createdAt   DateTime @default(now())

  interview Interview @relation(fields: [interviewId], references: [id], onDelete: Cascade)

  @@index([interviewId, createdAt])
}

model OrganizationInterviewQuota {
  id            String   @id @default(uuid())
  organizationId String  @unique
  totalGranted  Int      @default(500)
  reservedCount Int      @default(0)
  consumedCount Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  organization Organization          @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  ledgerEntries InterviewQuotaLedger[]
}

model InterviewQuotaLedger {
  id                 String                    @id @default(uuid())
  organizationQuotaId String
  interviewId        String?
  createdById        String?
  action             InterviewQuotaLedgerAction
  reason             InterviewQuotaLedgerReason
  deltaTotal         Int                       @default(0)
  deltaReserved      Int                       @default(0)
  deltaConsumed      Int                       @default(0)
  totalAfter         Int
  reservedAfter      Int
  consumedAfter      Int
  availableAfter     Int
  metadata           Json?
  createdAt          DateTime                  @default(now())

  organizationQuota OrganizationInterviewQuota @relation(fields: [organizationQuotaId], references: [id], onDelete: Cascade)
  interview         Interview?                 @relation(fields: [interviewId], references: [id], onDelete: SetNull)
  createdBy         User?                      @relation("QuotaLedgerActor", fields: [createdById], references: [id], onDelete: SetNull)

  @@index([organizationQuotaId, createdAt])
  @@index([interviewId])
  @@index([createdById])
}
