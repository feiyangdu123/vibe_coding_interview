{
  "$schema": "https://turborepo.com/schema.json",
  "globalEnv": [
    "NEXT_PUBLIC_CONTROL_PLANE_ORIGIN"
  ],
  "tasks": {
    "build": {
      "dependsOn": [
        "^build"
      ],
      "outputs": [
        "dist/**",
        ".next/**"
      ]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "typecheck": {
      "dependsOn": [
        "^typecheck"
      ],
      "outputs": []
    }
  }
}
