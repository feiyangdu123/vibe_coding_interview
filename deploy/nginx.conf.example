map $http_upgrade $connection_upgrade {
    default upgrade;
    '' close;
}

upstream vibe_web {
    server 127.0.0.1:3000;
}

upstream vibe_api {
    server 127.0.0.1:3001;
}

upstream opencode_1 {
    server 127.0.0.1:4100;
}

upstream opencode_2 {
    server 127.0.0.1:4101;
}

upstream opencode_3 {
    server 127.0.0.1:4102;
}

upstream opencode_4 {
    server 127.0.0.1:4103;
}

upstream opencode_5 {
    server 127.0.0.1:4104;
}

server {
    listen 80;
    server_name demo.example.com oc1.example.com oc2.example.com oc3.example.com oc4.example.com oc5.example.com;

    return 301 https://$host$request_uri;
}

server {
    listen 443 ssl http2;
    server_name demo.example.com;

    ssl_certificate /etc/nginx/ssl/demo.example.com/fullchain.pem;
    ssl_certificate_key /etc/nginx/ssl/demo.example.com/privkey.pem;

    client_max_body_size 20m;

    location /api/ {
        proxy_pass http://vibe_api;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection $connection_upgrade;
        proxy_read_timeout 300s;
        proxy_send_timeout 300s;
    }

    location / {
        proxy_pass http://vibe_web;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection $connection_upgrade;
        proxy_read_timeout 300s;
        proxy_send_timeout 300s;
    }
}

server {
    listen 443 ssl http2;
    server_name oc1.example.com;

    ssl_certificate /etc/nginx/ssl/oc1.example.com/fullchain.pem;
    ssl_certificate_key /etc/nginx/ssl/oc1.example.com/privkey.pem;

    location / {
        proxy_pass http://opencode_1;
        proxy_http_version 1.1;
        proxy_buffering off;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection $connection_upgrade;
        proxy_read_timeout 3600s;
        proxy_send_timeout 3600s;
    }
}

