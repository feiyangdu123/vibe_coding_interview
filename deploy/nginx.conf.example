    listen 443 ssl http2;
    server_name oc2.example.com;

    ssl_certificate /etc/nginx/ssl/oc2.example.com/fullchain.pem;
    ssl_certificate_key /etc/nginx/ssl/oc2.example.com/privkey.pem;

